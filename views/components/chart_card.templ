package components

templ ChartCard(title string, chartId string, chartBoxStyle string) {
    <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800">
        <h3 class="text-lg font-bold mb-4 text-slate-400">
            { title }
        </h3>
        if chartBoxStyle != "" {
            <div id={ chartId } class="chart-box" style={ chartBoxStyle }></div>
        } else {
            <div id={ chartId } class="chart-box"></div>
        }
    </div>
}
